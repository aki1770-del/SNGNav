app.*.symbols

# Obfuscation related
app.*.map.json

# Android Studio will place build artifacts here
/android/app/debug
/android/app/profile
/android/app/release

# Offline map tiles (large binary — see README for generation instructions)
data/*.mbtiles

# Flutter metadata
.flutter-plugins
.metadata

# Flutter ephemeral plugin symlinks
linux/flutter/ephemeral/

# Package lock files (packages are libraries — consumers resolve deps)
packages/*/pubspec.lock

# Lock file — kept for the app (reproducible builds)
# Uncomment if publishing the app as a package:
# pubspec.lock
